# Northstar - Environment Configuration Template
# Copy this file to .env before starting the app:
# cp .env.example .env

# ==============================================================================
# 1. Google Gemini API Configuration (REQUIRED)
# ==============================================================================
# How to get:
# 1. Go to Google AI Studio: https://aistudio.google.com/
# 2. Click "Get API Key" and generate a key.
# 3. Paste the key below.
GOOGLE_API_KEY=your_gemini_api_key_here

# The Gemini model to target. 
# Recommended: gemini-2.5-flash (fast, inexpensive)
# Alternative: gemini-3.1-pro-preview (advanced reasoning)
GOOGLE_MODEL=gemini-2.5-flash

# Set to true if you are deploying inside Google Cloud Platform using Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=false

# ==============================================================================
# 2. Parallel Search API Configuration (OPTIONAL)
# ==============================================================================
# How to get:
# 1. Sign up/Log in to Parallel Search: https://parallel.so/
# 2. Go to your API settings and copy your key.
# 3. Paste the key below to enable advanced live web competitive search.
PARALLEL_API_KEY=your_parallel_api_key_here

# Search modes: "basic" or "advanced"
PARALLEL_SEARCH_MODE=basic

# ==============================================================================
# 3. Agent Runtime Orchestration Configuration (OPTIONAL)
# ==============================================================================
# Options: 
# - "auto" (detects if google-adk is installed, falls back to local rules if not)
# - "google" (forces google-adk backend, fails if not available)
# - "local" (forces local heuristic rule fallback backend)
ADK_BACKEND=auto
